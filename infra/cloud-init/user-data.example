#cloud-config
#
# PolyUMI Raspberry Pi — first-boot configuration TEMPLATE.
#
# DO NOT edit this file directly. Instead:
#   cp infra/cloud-init/user-data.example infra/cloud-init/user-data
# Then edit user-data locally (it is gitignored).
#
# See docs/pi-provisioning.md for the full flashing workflow.

hostname: polyumi-pi
manage_etc_hosts: true

keyboard:
  layout: us

users:
  - name: pi
    groups: [adm, dialout, sudo, audio, video, plugdev, input, render, netdev, gpio, i2c, spi]
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    lock_passwd: false
    plain_text_passwd: 'polyumi!'
    ssh_authorized_keys:
      - ssh-ed25519 AAAA...  # TODO replace with your public key

# Disable password auth over SSH since we use keys; console login still works
ssh_pwauth: false
# Additional Raspberry Pi OS option (not available on generic cloud-init images)
enable_ssh: true  # Enables the SSH server on first boot

# TODO set the system timezone (set this to your local timezone for accurate timestamps in logs, etc.)
timezone: America/Chicago

rpi:
    spi: true               # Enable SPI interface
    i2c: true               # Enable I2C interface
    serial: true            # Enable serial console and UART interface
    onewire: true           # Enable 1-Wire interface
    enable_usb_gadget: true # Enable USB gadget mode

# picamera2 must come from apt (not pip) — it links against libcamera system libs.
# libportaudio2 is the backend required by sounddevice.
# libcamera-apps-lite provides rpicam-still / rpicam-vid for camera debugging.
packages:
  - vim
  - git
  - rsync
  - curl
  - wget
  - dkms                  # required by WM8960 audio HAT installer
  - python3-picamera2
  - python3-libcamera
  # - libcamera-apps-lite
  - rpicam-apps-lite
  - libportaudio2

package_update: true
package_upgrade: true

write_files:
  # Hardware PWM — required by rpi-hardware-pwm (LED / gripper control).
  # GPIO12 = PWM0, GPIO13 = PWM1. Pins 12/13 chosen to free GPIO18/19 for
  # the WM8960 audio HAT, which uses those pins for I2S.
  # Verify after boot with: lsmod | grep pwm  (expect pwm_bcm2835)
  - path: /boot/firmware/config.txt
    content: |
      dtoverlay=pwm-2chan,pin=12,func=4,pin2=13,func2=4
    append: true

  # Load brcmfmac WiFi driver on boot — needed on some Pi hardware revisions
  # where the driver isn't auto-loaded and WiFi doesn't appear on first scan.
  - path: /etc/modules-load.d/brcmfmac.conf
    content: |
      brcmfmac

  # Autostart service — runs `polyumi-pi start-scene` as pi user on boot.
  # Bring up/down manually with: sudo systemctl start|stop polyumi-pi
  # View logs: tail -f /var/log/polyumi-pi.log  or  journalctl -u polyumi-pi
  - path: /etc/systemd/system/polyumi-pi.service
    owner: root:root
    permissions: '0644'
    content: |
      [Unit]
      Description=PolyUMI Pi
      After=network.target

      [Service]
      User=pi
      WorkingDirectory=/home/pi
      Environment=GPIOZERO_PIN_FACTORY=lgpio
      Environment=LG_WD=/home/pi
      ExecStart=/home/pi/PolyUMI/pi/.venv/bin/python -m polyumi_pi.main start-scene
      Restart=on-failure
      RestartSec=5
      StandardOutput=append:/var/log/polyumi-pi.log
      StandardError=append:/var/log/polyumi-pi.log

      [Install]
      WantedBy=multi-user.target

runcmd:
  # WM8960 audio HAT — kernel default driver doesn't work; use Waveshare DKMS driver.
  # Validate after boot: arecord -D hw:wm8960soundcard -r 48000 -f S16_LE -c 2 -d 5 test.wav
  - git clone https://github.com/waveshare/WM8960-Audio-HAT /tmp/WM8960-Audio-HAT
  - DEBIAN_FRONTEND=noninteractive bash /tmp/WM8960-Audio-HAT/install.sh
  # Bluetooth — on fresh Trixie the adapter is rfkill-soft-blocked and bluetoothd
  # leaves it unpowered. Unblock now + enable auto-power on future boots so BLE
  # clients (open-gopro, etc.) find a ready adapter without manual steps.
  - rfkill unblock bluetooth
  - sed -i -E 's/^[[:space:]]*#[[:space:]]*(AutoEnable[[:space:]]*=).*/\1true/' /etc/bluetooth/main.conf
  - systemctl restart bluetooth
  # Install uv for the pi user
  - sudo -u pi bash -c 'curl -LsSf https://astral.sh/uv/install.sh | sh'
  # Create recordings directory
  - sudo -u pi mkdir -p /home/pi/recordings
  # PiSugar power manager daemon (battery management / RTC)
  # note that we have no way of pinning the release here as best as I can tell;
  # the version i've tested this on is currently 2.3.2, which is visible at the top of the file.
  # so we make do with failing loudly if they update the version by checking the hash.
  - wget --https-only https://cdn.pisugar.com/release/pisugar-power-manager.sh -P /tmp
  - echo "9b235a34b1f94940396476535d12323b4cf30448f985f9575584fa3a87d9c7e8  /tmp/pisugar-power-manager.sh" | sha256sum --check
  - DEBIAN_FRONTEND=noninteractive bash /tmp/pisugar-power-manager.sh -c release
  # NOTE: code deployment and ALSA preset are handled by deploy.sh, not cloud-init.
  # Run ./deploy.sh <hostname> from your PC after cloud-init finishes.
  # NOTE: polyumi-pi.service is installed but NOT enabled here. After cloud-init
  # finishes, SSH in, pair the GoPro (scan-gopro), then `systemctl enable polyumi-pi`
  # and reboot. See docs/pi-provisioning.md.

final_message: "PolyUMI Pi cloud-init complete after $UPTIME seconds. See docs/pi-provisioning.md for next steps."
